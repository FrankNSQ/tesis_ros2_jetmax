<?xml version="1.0"?>
<robot name="red_box">

  <link name="red_box_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0000033333" ixy="0.0" ixz="0.0"
               iyy="0.0000033333" iyz="0.0" izz="0.0000033333"/>
    </inertial>
  </link>

  <gazebo reference="red_box_link">
    <material>Gazebo/Red</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>

</robot>
